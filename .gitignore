# Local Netlify folder
.netlify

# Dependencies
node_modules/

# macOS
.DS_Store

# Claude Code
# Ignore .claude contents EXCEPT skills/ — cloud routines need project skills
# tracked to discover them. Must be `.claude/*`, not `.claude/`: git will not
# descend into an excluded directory, so a negation under it never fires.
.claude/*
!.claude/skills/
# No trailing slash: .claude/agents is a symlink, and git treats symlinks as
# files — a trailing-slash pattern matches directories only and would miss it.
!.claude/agents

# Temp files
temporary screenshots/
*.tmp
